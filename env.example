# Mealie Maintenance Suite — environment config
# Copy this file to .env and fill in your values.
# .env is gitignored and never committed.

# Your Mealie instance URL — no trailing slash
MEALIE_URL=http://your-mealie-host:9925

# Your Mealie API token (Settings → API Tokens)
# NOTE: the suite fetches your group slug automatically from the API
# so recipe URLs will be correct regardless of your group name.
MEALIE_TOKEN=your_api_token_here
